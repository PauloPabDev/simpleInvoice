---
// EmailActions — toolbar for copy HTML, download, and print
---

<div class="email-actions" id="email-actions">

  <a href="/correos" class="btn btn-sm btn-ghost">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
    Plantillas
  </a>

  <a href="/correo-editor?new=1" id="em-btn-edit" class="btn btn-sm btn-ghost">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
      <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
    </svg>
    Editar
  </a>

  <button type="button" class="btn btn-sm btn-ghost" id="em-btn-copy">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
      <rect x="9" y="9" width="13" height="13" rx="2"/>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
    </svg>
    Copiar HTML
  </button>

  <button type="button" class="btn btn-sm btn-ghost" id="em-btn-download">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
      <polyline points="7 10 12 15 17 10"/>
      <line x1="12" y1="15" x2="12" y2="3"/>
    </svg>
    Descargar .html
  </button>

  <button type="button" class="btn btn-sm btn-ghost" onclick="window.print()">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
      <polyline points="6 9 6 2 18 2 18 9"/>
      <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
      <rect x="6" y="14" width="12" height="8"/>
    </svg>
    Imprimir
  </button>

  <span class="em-copy-toast" id="em-copy-toast" aria-live="polite"></span>
</div>

<style>
  .email-actions {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .em-copy-toast {
    font-size: 12px;
    color: var(--emerald-dark);
    font-weight: 500;
    padding: 4px 10px;
    background: var(--emerald-subtle);
    border-radius: var(--r-full);
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }

  .em-copy-toast.visible {
    opacity: 1;
  }

  @media (max-width: 640px) {
    .email-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .email-actions > * {
      justify-content: center;
      min-width: 0;
    }
    .em-copy-toast {
      grid-column: 1 / -1;
      text-align: center;
    }
  }

  @media print {
    .email-actions { display: none !important; }
  }
</style>
